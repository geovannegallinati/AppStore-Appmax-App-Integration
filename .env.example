APP_NAME='AppMax AppStore App Checkout Demo'
APP_ENV=local
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8080
APP_URL=http://localhost:8080
APP_KEY=

NGROK_URL=
# Leave it in blank if you want to use a dynamic URL assigned by ngrok during make install. If you want to use a static URL, set it up in your ngrok account and put it here (e.g. foo.ngrok-free.app).

NGROK_AUTHTOKEN=
# Optional: static ngrok domain (e.g. foo.ngrok-free.app). If empty, a dynamic URL is assigned and printed during make install.

MODULE_PATH=github.com/geovanne-gallinati/AppStoreAppDemo

DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=appmax_checkout
DB_USERNAME=appmax
DB_PASSWORD=secret

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis-secret

NGROK_URL=sana-sagittate-hyperemotively.ngrok-free.app
# Leave it in blank if you want to use a dynamic URL assigned by ngrok during make install. If you want to use a static URL, set it up in your ngrok account and put it here (e.g. foo.ngrok-free.app).
NGROK_AUTHTOKEN=3AuFsIRbEHlmDWboBMNeTU6lK0Y_2jpp3sEYmnByL3hURArcs
# Optional: static ngrok domain (e.g. foo.ngrok-free.app). If empty, a dynamic URL is assigned and printed during make install.

# APPMAX_AUTH_URL defaults to https://auth.appmax.com.br (sandbox: https://auth.sandboxappmax.com.br)
# APPMAX_API_URL defaults to https://api.appmax.com.br (sandbox: https://api.sandboxappmax.com.br)
# APPMAX_ADMIN_URL defaults to https://admin.appmax.com.br (sandbox: https://breakingcode.sandboxappmax.com.br)
APPMAX_AUTH_URL=https://auth.sandboxappmax.com.br
APPMAX_API_URL=https://api.sandboxappmax.com.br
APPMAX_ADMIN_URL=https://breakingcode.sandboxappmax.com.br

# AppStore Credentials for your App.
APPMAX_CLIENT_ID=
APPMAX_CLIENT_SECRET=
APP_ID_UUID=

# Only for testing purposes. Credentials of login of the frontend page of https://breakingcode.sandboxappmax.com.br to test end-to-end integration
APPMAX_LOGIN='example.example.com'
APPMAX_PASSWORD='your-password-example-123'
